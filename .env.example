# ---- Telegram ----
# Get this from @BotFather
BOT_TOKEN=123456:your-telegram-bot-token-here
# Bot username WITHOUT @ (used to build deep links: t.me/<BOT_USERNAME>?start=<token>)
BOT_USERNAME=your_bot_username

# ---- Database ----
# SQLite for development (async driver). For PostgreSQL use e.g.:
# postgresql+asyncpg://user:password@localhost:5432/anon_bot
DATABASE_URL=sqlite+aiosqlite:///./anon_bot.sqlite3

# ---- App ----
# debug | info | warning | error
LOG_LEVEL=info

# ---- Rate limiting (anti-spam) ----
# Max anonymous messages a sender may send within the window
RATE_LIMIT_MAX_MESSAGES=5
# Window length in seconds
RATE_LIMIT_WINDOW_SECONDS=60
# Cooldown (seconds) between two consecutive messages from the same user
RATE_LIMIT_COOLDOWN_SECONDS=2

# ---- Limits ----
# Max length of an anonymous message / reply
MAX_MESSAGE_LENGTH=4000
